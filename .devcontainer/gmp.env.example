# Copy to gmp.env (gitignored) and fill. Sourced by scripts/codespace-kali-mcp.sh before starting kali-mcp.
# In GitHub Codespaces you can also set these as user/org secrets and export them in ~/.bashrc.

# gvmd / GMP listener (remote VM, host Docker, or local Greenbone in another container)
# KALI_MCP_GMP_HOST=host.docker.internal
# KALI_MCP_GMP_HOST=10.0.0.5
# KALI_MCP_GMP_PORT=9390
# KALI_MCP_GMP_USER=admin
# KALI_MCP_GMP_PASSWORD=your-gmp-or-admin-password

# PEM of the *server* TLS cert (gvm-cli verifies gvmd with this)
# KALI_MCP_GMP_CAFILE=/workspaces/kali-mcp/certs/gmp-tls-server.crt
# or pull from a Greenbone GCE export / docker-openvas

# Development only: skip cert verification (same as gvm-cli tls --insecure)
# KALI_MCP_GMP_TLS_INSECURE=1
